# Optional Semantic Scholar API key.
# Get one at: https://www.semanticscholar.org/product/api
S2_API_KEY=

# Optional runtime override for config/research_radar.yaml pipeline.default_fetch_source.
# Values: both, arxiv, semantic_scholar, or s2
FETCH_SOURCE=both

# Optional path override if you want to use a different YAML config file.
# RESEARCH_RADAR_CONFIG=config/research_radar.yaml

# Optional Ollama runtime overrides. Defaults live in config/research_radar.yaml.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:14b

# Set to true only when actively editing backend code and you want uvicorn reload.
RESEARCH_RADAR_RELOAD=false

# Optional output location for generated Markdown notes/digests.
# Can point at an Obsidian vault; leave blank to write to ./output.
OUTPUT_DIR=
